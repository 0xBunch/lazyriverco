{
  "name": "lazyriverco",
  "version": "0.4.2",
  "private": true,
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:seed": "dotenv -e .env.local -- tsx prisma/seed.ts",
    "db:seed:reset": "dotenv -e .env.local -- tsx prisma/seed.ts --reset",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:validate": "dotenv -e .env.local -- prisma validate",
    "db:update-bibles": "dotenv -e .env.local -- tsx prisma/update-bibles.ts",
    "eval:injection": "tsx scripts/evals/library-injection.ts",
    "backfill:ai-tags": "dotenv -e .env.local -- tsx scripts/backfill-ai-tags.ts"
  },
  "prisma": {
    "seed": "dotenv -e .env.local -- tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@aws-sdk/client-s3": "^3.1031.0",
    "@aws-sdk/s3-presigned-post": "^3.1031.0",
    "@aws-sdk/s3-request-presigner": "^3.1031.0",
    "@google/genai": "^1.50.1",
    "@prisma/client": "^6.19.3",
    "@tabler/icons-react": "^3.41.1",
    "@tailwindcss/typography": "^0.5.19",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "motion": "^12.38.0",
    "next": "^14.2.35",
    "node-ical": "^0.26.0",
    "pg-listen": "^1.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "replicate": "^1.4.0",
    "rss-parser": "^3.13.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.19.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "dotenv-cli": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35",
    "postcss": "^8.5.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "^5.5.4"
  }
}
