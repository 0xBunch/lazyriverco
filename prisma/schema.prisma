datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  name         String   @unique
  displayName  String
  email        String?  @unique
  avatarUrl    String?
  role         Role     @default(MEMBER)
  passwordHash String?
  sessionEpoch Int      @default(0)
  createdAt    DateTime @default(now())

  /// Free-form prose blurb the admin curates per member. Injected verbatim
  /// into agent prompts as part of the "here's the crew" context block.
  blurb        String?  @db.Text
  /// Optional structured fields the admin can fill in. Empty by default.
  city         String?
  favoriteTeam String?

  /// Feature flags the user has opted into. Membership is checked via
  /// `hasBetaFeature(user, "news")` in src/lib/feed-types.ts. Backed by
  /// a Postgres GIN index added in the migration so the gate can scale
  /// to more flags without a per-flag column. Allowed values live in
  /// the `BETA_FEATURES` literal tuple — adding one requires editing
  /// that tuple; no migration needed.
  betaFeatures String[] @default([])

  messages            Message[]
  picks               Pick[]
  votes               Vote[]
  rsvps               RSVP[]
  media               Media[]
  agentRelationships  AgentRelationship[]
  conversations       Conversation[]
  rateLimitHits       RateLimitHit[]
  pins                Pin[]
  comments            Comment[]
  usageEvents         LLMUsageEvent[]
  feeds               Feed[]
  // Draft 2026 back-relations. Named on DraftPick because it carries two
  // FKs to User (the picker vs the person who hit the Lock button — same
  // user in the normal case, different when admin picks on behalf).
  draftSlots          DraftSlot[]
  draftPicksMade      DraftPick[]         @relation("DraftPickMaker")
  draftPicksLocked    DraftPick[]         @relation("DraftPickLocker")
}

enum Role {
  MEMBER
  ADMIN
}

model Character {
  id                  String   @id @default(uuid())
  name                String   @unique
  displayName         String
  avatarUrl           String?
  systemPrompt        String   @db.Text
  isFantasyManager    Boolean  @default(false)
  triggerKeywords     String[]
  responseProbability Float    @default(0.3)
  activeModules       String[]
  active              Boolean  @default(true)
  /// Marks the single default/"home" character new Conversations default to
  /// (Moises, seeded by the phase-1 migration). Enforced as a partial unique
  /// index in the migration (`CREATE UNIQUE INDEX "Character_isDefault_key"
  /// ON "Character"("isDefault") WHERE "isDefault" = true`) because Prisma
  /// can't model partial predicates in @@unique. Flipped at runtime via
  /// `setDefaultAgent` in src/app/(portal)/admin/agents/actions.ts. The
  /// legacy `DEFAULT_CHARACTER_ID` constant in src/lib/characters.ts is the
  /// migration seed value — runtime callers should rely on this DB flag,
  /// not the constant.
  isDefault           Boolean  @default(false)
  /// When true, the agent may give longer, proportional replies and may
  /// optionally emit <followups>…</followups> tags at the end of a reply
  /// for clickable suggestion chips. When false (default), the agent stays
  /// terse — the "1-3 sentences, group-chat" tail applies. Flipped per
  /// persona via /admin/agents.
  dialogueMode        Boolean  @default(false)
  /// Anthropic model ID used for this agent's chat responses. Validated
  /// against the allowlist in src/lib/anthropic.ts (AGENT_MODELS). Default
  /// mirrors CHAT_MODEL so pre-existing agents keep their current model.
  model               String   @default("claude-sonnet-4-6")
  /// Admin-curated display order for agent pickers (homepage card, chats
  /// filter, relationships matrix, admin list). Lower sorts first; ties
  /// broken by displayName. Backfilled by the migration from the prior
  /// alphabetical order so the UX is unchanged on first load.
  displayOrder        Int      @default(0)
  createdAt           DateTime @default(now())

  messages            Message[]
  picks               Pick[]
  agentChannels       AgentChannel[]
  agentRelationships  AgentRelationship[]
  conversations       Conversation[]
  pins                Pin[]
  playerTakes         PlayerAgentTake[]
  draftReactions      DraftPickReaction[]

  @@index([displayOrder])
}

/// A conversational lane inside the Mens League clubhouse. v1 ships exactly
/// one channel (`mensleague`) but the schema is multi-channel-ready so we
/// can add #trips, #picks, #media without another migration.
model Channel {
  id          String   @id @default(uuid())
  slug        String   @unique
  displayName String
  description String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  messages    Message[]
  agents      AgentChannel[]
}

/// Join table — which agents are eligible to be summoned in which channels.
/// In v1 all 3 agents live in #mensleague; in the future Joey could be
/// scoped to #fantasy and Andreea to #trips, etc.
model AgentChannel {
  characterId String
  channelId   String

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  channel   Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([characterId, channelId])
}

/// Per-(agent, member) free-form narrative — what this specific agent
/// thinks about this specific member. Edited by the admin via /admin.
/// Injected into agent prompts when responding in a channel where the
/// target user is present.
model AgentRelationship {
  id           String   @id @default(uuid())
  characterId  String
  targetUserId String
  content      String   @db.Text
  updatedAt    DateTime @default(now()) @updatedAt

  character  Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  targetUser User      @relation(fields: [targetUserId], references: [id], onDelete: Cascade)

  @@unique([characterId, targetUserId])
  // The compound unique index covers (characterId) leftmost-prefix lookups.
  // This separate index covers the prompt-injection query path:
  // "give me every relationship targeting user X."
  @@index([targetUserId])
}

/// Single-row convention: the broader Mens League lore. History, running
/// inside jokes, league rules, rivalries. The `name` field is provisioned
/// for future per-channel canon docs but unused in v1 (always "default").
model ClubhouseCanon {
  id        String   @id @default(uuid())
  name      String   @unique @default("default")
  content   String   @db.Text
  updatedAt DateTime @default(now()) @updatedAt
}

/// Per-user conversation thread with a single AI character. Distinct from
/// Channel (which is a multi-user shared lane). Phase 1 of the lazy-river
/// refactor introduces Conversations as the default chat surface; the
/// legacy Channel path is preserved for admin review of #mensleague.
model Conversation {
  id            String    @id @default(uuid())
  ownerId       String
  characterId   String
  /// First ~50 chars of the first user message, shown in sidebar history.
  title         String?   @db.VarChar(200)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  /// Mirror of the newest Message.createdAt — cheap sort key for the
  /// sidebar "recent" list without joining Message on every render.
  lastMessageAt DateTime  @default(now())
  /// Soft-delete. Non-null hides from sidebar + routes.
  archivedAt    DateTime?

  owner     User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Restrict)
  messages  Message[]
  pins      Pin[]

  // Sidebar read path: "recent conversations for this user".
  @@index([ownerId, lastMessageAt(sort: Desc)])
}

model Message {
  id             String      @id @default(uuid())
  module         String      @default("chat")
  /// Legacy group-channel FK. Nullable because new rows written via the
  /// per-user Conversation path set `conversationId` instead. Exactly one
  /// of channelId/conversationId is set — enforced at the DB level by a
  /// raw-SQL CHECK constraint added in the phase-1 migration (Prisma can't
  /// model CHECK in schema.prisma, so it lives in the migration file).
  channelId      String?
  /// Per-user conversation FK, new in phase 1 of the lazy-river refactor.
  conversationId String?
  authorType     AuthorType
  userId         String?
  characterId    String?
  content        String      @db.Text
  mediaUrl       String?
  parentId       String?
  createdAt      DateTime    @default(now())

  channel      Channel?      @relation(fields: [channelId], references: [id], onDelete: Restrict)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id])
  character    Character?    @relation(fields: [characterId], references: [id])
  parent       Message?      @relation("Replies", fields: [parentId], references: [id])
  replies      Message[]     @relation("Replies")

  // Read pattern: "give me the last N messages in channel X by time".
  @@index([channelId, createdAt(sort: Desc)])
  // Same pattern but scoped to a Conversation (the new per-user path).
  @@index([conversationId, createdAt(sort: Desc)])
}

enum AuthorType {
  USER
  CHARACTER
}

/// Reference dump of the Sleeper player DB (~11k rows). Refreshed at most
/// daily from https://api.sleeper.app/v1/players/nfl. Used to hydrate the
/// player IDs that appear in a Sleeper roster (players[] array) and
/// transaction (adds/drops keyed by playerId) into human-readable names.
/// Not league-scoped — Sleeper's player IDs are global across leagues.
model SleeperPlayer {
  playerId         String   @id
  firstName        String?
  lastName         String?
  fullName         String?
  position         String?
  team             String?
  fantasyPositions String[] @default([])
  status           String?
  injuryStatus     String?
  active           Boolean  @default(true)
  /// Years of NFL experience from Sleeper's raw `/players/nfl` payload.
  /// `0` = rookie (drafted this year OR undrafted-free-agent on a roster).
  /// Nullable because Sleeper occasionally omits it for late UDFA signings.
  /// Populated by runPlayersSync in src/lib/sleeper.ts; used by the draft
  /// 2026 rookie-pool query (QB/RB/WR/TE + yearsExp=0 + team IS NOT NULL).
  yearsExp         Int?
  /// NFL draft year from Sleeper's raw payload. Not always present for
  /// UDFAs; treat as advisory. Distinct from `yearsExp=0` because a
  /// rookie's draftYear could be (current season - yearsExp) but Sleeper
  /// is the source of truth when present.
  draftYear        Int?
  updatedAt        DateTime @updatedAt

  stats            PlayerSeasonStats[]
  projections      PlayerSeasonProjection[]
  agentTakes       PlayerAgentTake[]
  partnerInfo      PlayerPartnerInfo?
  draftPicks       DraftPick[]
  draftPool        DraftPoolPlayer[]
  shadowPicks      DraftShadowPick[]
  scoutingReport   RookieScoutingReport?

  @@index([team])
  @@index([position])
  // Supports the rookie-pool query: where yearsExp=0 AND position IN (...)
  // AND team IS NOT NULL. Covers the prefix (yearsExp, position, team).
  @@index([yearsExp, position, team])
}

/// One-shot cache of the player's publicly-known wife / girlfriend /
/// fiancée / partner — populated lazily on first profile view via a
/// Claude + web_search call that returns structured JSON. The row
/// always exists after the first lookup even when no partner was
/// found (relationship = "not_found"), so we don't re-query the web
/// every page view. Admin re-rolls by deleting the row.
model PlayerPartnerInfo {
  id            String   @id @default(uuid())
  playerId      String   @unique
  name          String?
  /// One of: 'wife' | 'fiancee' | 'girlfriend' | 'partner' | 'not_found'.
  /// Stored as text rather than enum so future additions (e.g. "spouse",
  /// "divorced") don't require a migration.
  relationship  String
  notableFact   String?  @db.Text
  /// Hotlink URL. Whitelist-validated at write time (Wikimedia / a small
  /// set of CDNs that the UI tolerates). Nullable when no usable image
  /// was returned or the URL failed validation.
  imageUrl      String?
  sourceUrl     String?
  /// Instagram username with no leading @. Validated at write time
  /// against Instagram's handle rules (1-30 chars, alphanumeric +
  /// underscore + period). Nullable when Gemini couldn't find one.
  /// UI renders as `@handle` linking to instagram.com/{handle}.
  instagramHandle String?
  /// 'low' | 'medium' | 'high'. Surfaces on the card when < high so
  /// viewers don't read soft-confidence data as gospel.
  confidence    String   @default("low")
  checkedAt     DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  player        SleeperPlayer @relation(fields: [playerId], references: [playerId], onDelete: Cascade)
}

/// Per-player per-season totals from the undocumented
/// /v1/stats/nfl/regular/{season} endpoint. Also stores the week-by-week
/// PPR points as a JSON array for sparkline rendering on the player
/// profile page.
model PlayerSeasonStats {
  id           String   @id @default(uuid())
  playerId     String
  season       String
  ptsPpr       Float    @default(0)
  ptsHalfPpr   Float    @default(0)
  ptsStd       Float    @default(0)
  gamesPlayed  Int      @default(0)
  rankPpr      Int?
  posRankPpr   Int?
  /// Week-by-week PPR points: [{week: 1, pts: 20.5}, ...]. Empty when
  /// per-week endpoint hasn't been synced for this season yet.
  weeklyPpr    Json     @default("[]")
  updatedAt    DateTime @updatedAt

  player       SleeperPlayer @relation(fields: [playerId], references: [playerId], onDelete: Cascade)

  @@unique([playerId, season])
  @@index([season, ptsPpr(sort: Desc)])
}

/// Per-player per-season projections from /v1/projections/nfl/regular/{season}.
/// Separate from stats because semantics differ (ADP only meaningful for
/// projections; projected totals can exist for players who never played).
model PlayerSeasonProjection {
  id           String   @id @default(uuid())
  playerId     String
  season       String
  ptsPpr       Float    @default(0)
  ptsHalfPpr   Float    @default(0)
  gamesPlayed  Int      @default(0)
  /// ADP (average draft position) in PPR leagues. 999 = effectively undrafted.
  adpPpr       Float?
  adpHalfPpr   Float?
  updatedAt    DateTime @updatedAt

  player       SleeperPlayer @relation(fields: [playerId], references: [playerId], onDelete: Cascade)

  @@unique([playerId, season])
  @@index([season, ptsPpr(sort: Desc)])
}

/// One-liner take on a player from a specific clubhouse character. Generated
/// lazily on first profile view via a Claude one-shot per active character,
/// cached so subsequent views are free. Uniqueness is per (player, character)
/// so we can re-roll later by deleting the row.
model PlayerAgentTake {
  id          String    @id @default(uuid())
  playerId    String
  characterId String
  take        String    @db.Text
  createdAt   DateTime  @default(now())

  player      SleeperPlayer @relation(fields: [playerId], references: [playerId], onDelete: Cascade)
  character   Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([playerId, characterId])
  @@index([playerId])
}

/// One Claude-generated paragraph summarizing a completed season of an MLF
/// Sleeper league. Keyed by (leagueId, season) so switching to a different
/// historical chain hop just fetches/generates fresh. Regenerate by
/// deleting the row.
model LeagueSeasonNarrative {
  id         String   @id @default(uuid())
  leagueId   String
  season     String
  body       String   @db.Text
  createdAt  DateTime @default(now())

  @@unique([leagueId, season])
}

model Pick {
  id          String     @id @default(uuid())
  authorType  AuthorType
  userId      String?
  characterId String?
  type        String
  description String     @db.Text
  prediction  String
  odds        String?
  analysis    String?    @db.Text
  result      PickResult @default(PENDING)
  resolvedAt  DateTime?
  createdAt   DateTime   @default(now())

  user        User?      @relation(fields: [userId], references: [id])
  character   Character? @relation(fields: [characterId], references: [id])
}

enum PickResult {
  PENDING
  WIN
  LOSS
  PUSH
}

model Bracket {
  id          String   @id @default(uuid())
  title       String
  description String?
  size        Int
  status      String   @default("active")
  createdBy   String
  createdAt   DateTime @default(now())

  matchups    Matchup[]
}

model Matchup {
  id        String   @id @default(uuid())
  bracketId String
  round     Int
  position  Int
  entryA    String
  entryB    String?
  imageA    String?
  imageB    String?
  winner    String?
  votesA    Int      @default(0)
  votesB    Int      @default(0)
  active    Boolean  @default(false)
  createdAt DateTime @default(now())

  bracket   Bracket  @relation(fields: [bracketId], references: [id], onDelete: Cascade)
  votes     Vote[]
}

model Vote {
  id        String   @id @default(uuid())
  matchupId String
  userId    String
  choice    String
  createdAt DateTime @default(now())

  matchup   Matchup  @relation(fields: [matchupId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@unique([matchupId, userId])
}

model PowerRanking {
  id        String   @id @default(uuid())
  topic     String
  items     String[]
  userId    String
  createdAt DateTime @default(now())
}

model Media {
  id           String      @id @default(uuid())
  uploadedById String
  url          String
  thumbnailUrl String?
  type         String
  sourceUrl    String?
  tags         String[]
  hallOfFame   Boolean     @default(false)
  /// Upload lifecycle: PENDING after presign (before the client PUTs the
  /// file to R2), READY after the commit endpoint flips it, DELETED on
  /// soft-delete. buildRichContext only injects READY rows.
  status       MediaStatus @default(READY)
  /// Short human-written description injected into agent system prompts
  /// as part of the shared media bank section. Sanitized before injection
  /// (strip `#` headers + `<suggest-agent>` substrings + cap 200 chars)
  /// — see src/lib/media-context.ts.
  caption      String?
  /// Canonical mime type captured at presign time. Used by the content-
  /// type allowlist check and to pick <img> vs <video> rendering.
  mimeType     String?
  createdAt    DateTime    @default(now())

  /// Origin of the library item. UPLOAD = direct file upload to R2;
  /// YOUTUBE / X / INSTAGRAM / WEB = pasted URL processed by an ingest
  /// adapter. Drives tile treatment in /library and adapter dispatch
  /// in src/lib/ingest.
  origin         MediaOrigin @default(UPLOAD)
  /// OG title scraped at ingest. UNTRUSTED attacker-controlled text —
  /// MUST be sanitized (same primitives as Media.caption) before any
  /// LLM-facing injection. See src/lib/media-context.ts.
  originTitle    String?
  /// OG author / handle / channel name scraped at ingest. Same
  /// sanitization discipline as originTitle.
  originAuthor   String?
  /// True if the asset (photo, thumbnail) lives in our R2 bucket. False
  /// means we're still referencing the remote `ogImageUrl` — either by
  /// design (video embeds) or because the R2 copy failed at ingest.
  storedLocally  Boolean     @default(false)
  /// Cached oEmbed iframe HTML (X tweets, future providers). Sanitize at
  /// render time before inserting into the DOM. Null for origins that
  /// don't use embed iframes (UPLOAD, WEB, the IG OG-card path).
  embedHtml      String?     @db.Text
  /// Remote OG image URL. Pre-localize fallback source and the permanent
  /// URL for items where storedLocally=false.
  ogImageUrl     String?
  /// Per-user soft-hide ("drunk Sunday" escape hatch). Uploader or admin
  /// toggles. Hidden items don't appear in the /library grid, in search,
  /// or in the agent library_search tool — but remain linkable by id.
  hiddenFromGrid Boolean     @default(false)

  /// Gemini vision output — separate column from `tags` so admin bulk-ops
  /// can distinguish AI-applied tags from human-applied ones and reprocess
  /// selectively. Merged into the render-time tag list in the UI + into the
  /// FTS text at read-side. Slug-shape (TAG_SHAPE regex) same as `tags`.
  aiTags         String[]    @default([])
  /// Timestamp of the last successful vision run. Null = never analyzed;
  /// set on both success and soft-failure (see aiAnalysisNote).
  aiAnalyzedAt   DateTime?
  /// One of: null = success, "skipped: <reason>", "failed: <reason>".
  /// Lets the admin sweeper re-target rows with transient failures
  /// (rate-limit, 5xx) while leaving permanent skips (policy blocks) alone.
  aiAnalysisNote String?     @db.Text

  /// When non-null, the item was inserted by a MEDIA-kind Feed poll
  /// rather than a user paste. Used by the library "show auto-feed
  /// items" toggle (default off) and by /admin/feeds/[id] for the
  /// per-feed item browser. SetNull on feed delete so the Media row
  /// survives as a plain curated entry — we never want a feed
  /// deletion to cascade-delete the library.
  feedId          String?
  feed            Feed?                @relation(fields: [feedId], references: [id], onDelete: SetNull)

  uploadedBy      User                 @relation(fields: [uploadedById], references: [id])
  calendarEntries CalendarEntryMedia[]
  comments        Comment[]

  // Media retrieval path for buildRichContext: filter to READY, hall-of-
  // fame first, then most recent. Composite matches the ORDER BY so
  // Postgres can serve it as an index scan once the table grows.
  @@index([status, hallOfFame, createdAt(sort: Desc)])
  // Grid read path: filter by origin + status, order by recency. Covers
  // /library?origin=youtube and the admin "items by source" view.
  @@index([origin, status, createdAt(sort: Desc)])
  // Per-feed item listing for /admin/feeds/[id]. Unique on
  // (feedId, sourceUrl) is idempotency insurance for the feed
  // poller — concurrent runs across crashes can't create duplicate
  // Media rows for the same feed-item pair. Nullable sourceUrl is
  // common for direct uploads; Postgres treats NULL as distinct in
  // a compound unique, so that case is unaffected.
  @@index([feedId])
  @@unique([feedId, sourceUrl], map: "Media_feedId_sourceUrl_key")
  // Full-text search: functional GIN index on to_tsvector(caption+origin*+tags),
  // created in the migration SQL (Prisma can't model expression indexes).
  // Queries in src/lib/library-search.ts must use the same expression in
  // WHERE to hit this index. Stored columns via GENERATED STORED tripped
  // Postgres's IMMUTABLE check (to_tsvector is STABLE, not IMMUTABLE) — the
  // functional index is the idiomatic Postgres FTS pattern and dodges it.
}

enum MediaStatus {
  PENDING
  READY
  DELETED
}

/// Ingest origin discriminator. TikTok intentionally omitted in v1 — paste
/// is rejected at the adapter. Add the value here if/when we implement an
/// adapter for it.
enum MediaOrigin {
  UPLOAD
  INSTAGRAM
  YOUTUBE
  X
  WEB
}

/// Semantic grouping for tags. One row per bucket (people / places /
/// topics / vibes / banned). The actual slug membership used to live
/// here as a `slugs String[]` — that schema drifted from reality
/// (Media.tags[] had slugs nobody curated), so v1.5 promotes tags to a
/// first-class `Tag` entity and this table just owns the label +
/// sortOrder. Tags point back via Tag.bucketId.
model TaxonomyBucket {
  id          String   @id @default(uuid())
  label       String   @unique
  /// Human-written prose rule for what belongs in this bucket. Presence
  /// of a non-empty description makes this a "priority" bucket: it gets
  /// curated treatment in the Gemini vision prompt (scan-for-these
  /// framing) AND is the only bucket class the classify-uncategorized
  /// admin action will write into. Buckets without a description stay
  /// loose — useful for generic descriptors that pile up from Gemini
  /// output but aren't load-bearing for app/user flows.
  description String?  @db.Text
  sortOrder   Int      @default(0)
  updatedAt   DateTime @updatedAt

  tags Tag[]

  @@index([sortOrder])
}

/// Universal tag registry. Every distinct slug that appears anywhere
/// in `Media.tags`, `Media.aiTags`, or is curated via /admin/taxonomy
/// has a row here. Media.tags[] stays as String[] (FTS + filter code
/// untouched); this table is the registry mirror + metadata home.
///
/// bucketId assignment drives the Gemini prompt hint. Null = tag exists
/// in some Media row but hasn't been curated yet. Bucket with
/// label='banned' = server-side strip + prompt-level forbid (enforced
/// in src/lib/ai-taxonomy.ts + src/app/(portal)/admin/taxonomy/).
///
/// Usage counts are computed on demand via UNNEST aggregation on Media,
/// not denormalized — at this scale (< 1k rows) the query is sub-10ms
/// and keeping a counter in sync across write paths is the kind of
/// drift the admin page just fought against for arrays.
model Tag {
  id          String   @id @default(uuid())
  slug        String   @unique
  label       String?
  description String?  @db.Text
  bucketId    String?
  bucket      TaxonomyBucket? @relation(fields: [bucketId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([bucketId])
}

model LeaderboardEntry {
  id          String   @id @default(uuid())
  userId      String?
  characterId String?
  competition String
  season      Int?
  wins        Int      @default(0)
  losses      Int      @default(0)
  pushes      Int      @default(0)
  points      Float    @default(0)
  updatedAt   DateTime @updatedAt
}

model Event {
  id          String    @id @default(uuid())
  title       String
  description String?   @db.Text
  location    String?
  startTime   DateTime
  endTime     DateTime?
  createdBy   String
  createdAt   DateTime  @default(now())

  rsvps       RSVP[]
}

model RSVP {
  id      String @id @default(uuid())
  eventId String
  userId  String
  status  String

  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id])

  @@unique([eventId, userId])
}

model ScheduledContent {
  id        String    @id @default(uuid())
  type      String
  frequency String
  dayOfWeek Int?
  timeOfDay String?
  lastFired DateTime?
  active    Boolean   @default(true)
}

/// Human-authored comment on a library item. Distinct from Message
/// (which belongs to a Conversation) so we don't need a synthetic
/// conversation-per-media or nullable-conversationId pattern.
/// Soft-delete via deletedAt; tombstone renders as "[comment removed]"
/// in the UI. Replies are deferred to a follow-up — no parentId yet.
model Comment {
  id        String    @id @default(uuid())
  mediaId   String
  userId    String
  body      String    @db.Text
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  media Media @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  // Primary read path: "all comments for this media, chronological".
  @@index([mediaId, createdAt])
}

/// Per-user sliding-window rate-limit tracking. One row per successful
/// write on a rate-limited endpoint (conversation.create,
/// conversation.message). src/lib/rate-limit.ts counts rows inside a
/// trailing window and throws RateLimitError past the cap. Cleanup is a
/// periodic DELETE of rows older than 24h, wired in Task 3.
model RateLimitHit {
  id        String   @id @default(uuid())
  userId    String
  bucket    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, bucket, createdAt])
}

/// Topic-tagged knowledge chunk. Selected by a two-pass Haiku call based
/// on conversation relevance — only matching entries get injected into
/// the agent's system prompt, replacing the "dump everything" approach.
/// `isCore` entries bypass selection and are always injected (org
/// identity, essential rules). Admin-managed via /admin/lore.
model Lore {
  id        String   @id @default(uuid())
  topic     String
  tags      String[] @default([])
  content   String   @db.Text
  isCore    Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isCore, sortOrder])
}

/// Date-based knowledge entry. Birthdays, cultural moments (Super Bowl,
/// draft day), trip dates. Auto-injected into agent prompts when the
/// date is within ±7 days of today — no Haiku selection needed, purely
/// temporal relevance. `recurrence: "annual"` for birthdays; "none" for
/// one-time events. Separate from the Event/RSVP model (that's for trip
/// planning logistics, not agent knowledge). Admin-managed via
/// /admin/calendar.
model CalendarEntry {
  id            String   @id @default(uuid())
  title         String
  date          DateTime @db.Date
  /// Optional free-form time-of-day string (e.g. "7:00 PM", "Noon").
  /// Intentionally a string, not @db.Time — no TZ math, admins write what
  /// they mean. Null = all-day/untimed (birthdays, trip start dates, etc).
  /// Rendered only in the list view; the month grid ignores it.
  time          String?
  recurrence    String   @default("none")
  tags          String[] @default([])
  /// Short summary shown in admin list + agent context. Keep <200 chars.
  description   String?  @db.Text
  /// Long-form markdown body rendered on /calendar/[id]. Not injected into
  /// agent context (description is — keeping that channel tight).
  body          String?  @db.Text
  /// YouTube or Vimeo URL. Rendered as an iframe embed on the detail page.
  /// URL-only; video *upload* is intentionally not supported (cost + moderation).
  videoEmbedUrl String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  media         CalendarEntryMedia[]

  @@index([date])
}

/// Join between CalendarEntry and the shared Media bank. A Media row can
/// be attached to multiple entries (same trip photo could appear on the
/// trip entry and on a year-end recap entry), and an entry has an ordered
/// library of many media rows. Cover photo is a boolean on the join —
/// enforcing "at most one cover per entry" is app-level (Postgres partial
/// unique indexes aren't modeled in Prisma; if drift becomes a problem,
/// add a raw-SQL partial index in a follow-up migration).
model CalendarEntryMedia {
  id              String        @id @default(uuid())
  calendarEntryId String
  mediaId         String
  /// 0-indexed position within the entry's library. Ties broken by createdAt.
  position        Int           @default(0)
  /// At most one row per entry should carry isCover=true. App enforces.
  isCover         Boolean       @default(false)
  /// Per-attachment caption, distinct from Media.caption (which is the
  /// "global" caption injected into agent context). Leave null to fall
  /// back to Media.caption on the detail page.
  caption         String?       @db.Text
  createdAt       DateTime      @default(now())

  calendarEntry   CalendarEntry @relation(fields: [calendarEntryId], references: [id], onDelete: Cascade)
  media           Media         @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([calendarEntryId, mediaId])
  @@index([calendarEntryId, position])
  @@index([mediaId])
}

/// User-scoped pin. Polymorphic: exactly one of conversationId or
/// characterId is non-null — enforced at the DB level by a raw-SQL CHECK
/// constraint added in the migration (Prisma can't model CHECK here, so
/// it lives in the migration file, matching the precedent set by Message
/// for channelId/conversationId). Currently only conversation pins are
/// wired through the app; the character column is provisioned for a
/// later "starred agents" surface without needing a second migration.
model Pin {
  id             String   @id @default(uuid())
  userId         String
  conversationId String?
  characterId    String?
  createdAt      DateTime @default(now())

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  character    Character?    @relation(fields: [characterId], references: [id], onDelete: Cascade)

  // Idempotency — star the same thing twice is a no-op at the DB level.
  // Separate indexes per discriminator because nullable columns short-
  // circuit a single composite unique (null != null in postgres).
  @@unique([userId, conversationId])
  @@unique([userId, characterId])
  // Sidebar read path: "give me every pin for this user."
  @@index([userId, createdAt(sort: Desc)])
}

/// Admin-curated dropdown group shown beneath the homepage prompt box.
/// Each group renders as a button (e.g. "Write", "Roast", "Learn") that
/// opens a menu of its active PromptSuggestion items. Picking an item
/// pastes its full `prompt` text into the input. Managed via
/// /admin/prompts. Inactive groups and groups with zero active items are
/// hidden from the homepage.
model PromptGroup {
  id        String   @id @default(uuid())
  label     String
  /// Name of a Lucide icon from the curated allowlist in
  /// src/lib/prompt-icons.ts. Null = render label only. Unknown names
  /// silently downgrade to null at render time (getPromptIcon helper).
  icon      String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items PromptSuggestion[]

  // Homepage read path: active groups ordered by sortOrder.
  @@index([isActive, sortOrder])
}

/// One selectable suggestion inside a PromptGroup. `label` is the short
/// CTA shown in the dropdown ("SportsCenter intro"); `prompt` is the
/// full text pasted into the homepage input on click ("Write a
/// SportsCenter intro for Mike's fantasy team"). Cascade-delete with the
/// parent group so deleting a group cleans up its items.
model PromptSuggestion {
  id        String   @id @default(uuid())
  groupId   String
  label     String
  /// Lucide icon name — see PromptGroup.icon for the contract.
  icon      String?
  prompt    String   @db.Text
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  group PromptGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@index([groupId, sortOrder])
  @@index([groupId, isActive, sortOrder])
}

/// Append-only ledger of every LLM call the app makes. One row per
/// provider call (top-level generate*Response, tool-loop iteration, or
/// vision/Haiku helper). Columns cover the full cost-accounting surface
/// — token counts split by role, cache tokens, image count — plus the
/// stitching fields (`replyId`, `iteration`) that let us collapse a
/// multi-step tool loop back into a single "reply" in analytics.
///
/// Writes are fire-and-forget from the providers layer so a DB outage
/// can't take down chat. `userId`/`pricingId` use ON DELETE SET NULL so
/// a deleted user or retired pricing row never cascades away history.
///
/// Read path: per-user daily/weekly aggregation in /admin/usage, plus
/// future rate-limit "cost" budgets. Indexes below cover each of those
/// lookups (user+time DESC, model+time, operation+time, conversation+time,
/// and replyId for the stitch).
model LLMUsageEvent {
  id                  String   @id @default(uuid())
  userId              String?
  provider            String
  model               String
  operation           String
  /// UUID minted at the top of generate*Response. Every tool-loop
  /// iteration for the same user turn shares this value so analytics
  /// can collapse the loop into one "reply" unit.
  replyId             String?
  /// 0 for the first call in a reply, 1+ for subsequent tool-loop
  /// iterations. Always 0 for single-shot helpers (vision, Haiku lore).
  iteration           Int      @default(0)
  inputTokens         Int      @default(0)
  outputTokens        Int      @default(0)
  cacheReadTokens     Int      @default(0)
  cacheCreationTokens Int      @default(0)
  imageCount          Int      @default(0)
  estimatedCostUsd    Float    @default(0)
  /// FK to the ModelPricing row used to compute estimatedCostUsd at
  /// write time. SetNull on delete so retiring a pricing row doesn't
  /// erase historical events — the computed USD stays correct even if
  /// the source row disappears.
  pricingId           String?
  conversationId      String?
  messageId           String?
  characterId         String?
  mediaId             String?
  requestMs           Int?
  success             Boolean  @default(true)
  errorCode           String?
  createdAt           DateTime @default(now())

  user    User?         @relation(fields: [userId],    references: [id], onDelete: SetNull)
  pricing ModelPricing? @relation(fields: [pricingId], references: [id], onDelete: SetNull)

  // Primary read path for /admin/usage: "all events for a user, newest first".
  @@index([userId, createdAt(sort: Desc)])
  // Model breakdown: "spend by model over last N days".
  @@index([model, createdAt(sort: Desc)])
  // Operation breakdown: chat vs vision vs lore-selection etc.
  @@index([operation, createdAt(sort: Desc)])
  // Drill-down from a conversation to its call history.
  @@index([conversationId, createdAt(sort: Desc)])
  // Stitch a tool-loop reply back together for a single "reply cost".
  @@index([replyId])
}

/// Source-of-truth pricing per provider+model. Rates are USD per 1M
/// tokens (inputPerMTokUsd / outputPerMTokUsd) with optional separate
/// cache read/write rates for Anthropic prompt caching. Seeded with
/// Sonnet 4.6, Haiku 4.5, and Gemini 2.5 Flash at verified 2026-04-18
/// rates; admin updates this table when providers re-price.
///
/// LLMUsageEvent.pricingId points here with ON DELETE SET NULL so
/// retiring a row never destroys event history. `@unique` on model
/// guarantees one row per model string — the providers layer looks up
/// by model to stamp pricingId at write time.
model ModelPricing {
  id                   String   @id @default(uuid())
  provider             String
  model                String   @unique
  inputPerMTokUsd      Float
  outputPerMTokUsd     Float
  cacheReadPerMTokUsd  Float?
  cacheWritePerMTokUsd Float?
  /// Flat per-image surcharge. NULL for providers (Gemini) that fold
  /// image input into the regular token count — imageCount on the
  /// event is a product metric in that case, not a cost multiplier.
  perImageUsd          Float?
  notes                String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  events LLMUsageEvent[]
}

/// A single polled source — either an RSS feed (kind=NEWS, items go to
/// NewsItem) or a curated media URL source (kind=MEDIA, items go to
/// Media via the existing ingest pipeline). Ownership stays with the
/// admin who registered the feed; deleting the user is Restricted so
/// orphan feeds force a reassign rather than silently dropping a
/// running background job. Auto-disable kicks in after N consecutive
/// poll failures — admin has to re-enable manually.
///
/// Health is COMPUTED from the fields below (src/lib/feed-health.ts,
/// computeHealth). There is no stored health column — stale denormal-
/// ization bugs are the #1 source of "the dashboard is lying" tickets,
/// and the inputs (lastPolledAt, lastSuccessAt, lastError,
/// consecutivePollFailures, autoDisabledAt) are cheap to read.
model Feed {
  id                      String        @id @default(uuid())
  name                    String
  url                     String        @unique
  kind                    FeedKind
  /// Editorial category. GENERAL feeds power the library /news surface;
  /// SPORTS feeds power the /sports landing's headlines rail. Defaults
  /// to GENERAL — feeds shipped before the sports landing migration
  /// keep their existing semantics.
  category                FeedCategory  @default(GENERAL)
  /// Optional sport tag. Only meaningful when category=SPORTS — the
  /// poller propagates this to NewsItem.sport on insert so per-sport
  /// filtering on /sports works without an extra per-item write. Null
  /// on GENERAL feeds; admin UI clears it automatically when the
  /// category flips back to GENERAL.
  sport                   SportTag?
  enabled                 Boolean       @default(true)
  /// Minimum minutes between polls. Enforced by a CHECK constraint in
  /// the migration (5..1440). Exponential backoff on failure multiplies
  /// this value, capped at 24h — see feed-poller.ts.
  pollIntervalMin         Int           @default(30)
  ownerId                 String
  owner                   User          @relation(fields: [ownerId], references: [id], onDelete: Restrict)
  /// When the last poll actually started. Strictly observational —
  /// the cron's "can I poll now" gate reads `nextPollEligibleAt`, not
  /// this. Admin UIs show "last polled X min ago" from this column.
  lastPolledAt            DateTime?
  /// Earliest time the cron is allowed to poll this feed again. Set
  /// to `lastPolledAt + pollIntervalMin` on success and to
  /// `lastPolledAt + exponential-backoff` on failure (capped at 24h).
  /// Separate from lastPolledAt so an admin reading the row never
  /// sees a future timestamp in the "last polled" column — the
  /// observable "when did it poll" and the gate "when can it poll"
  /// are distinct facts.
  nextPollEligibleAt      DateTime?
  /// Distinct from lastPolledAt: lets the health chip distinguish
  /// "polls are fine but feed hasn't published anything" (STALE) from
  /// "polls are failing" (DEGRADED).
  lastSuccessAt           DateTime?
  /// Most recent item's publishedAt (or ingestedAt if null). Used by
  /// the STALE health check (>30 days).
  lastItemAt              DateTime?
  /// Last error message, truncated to 2000 chars at write time so a
  /// 10MB HTML error response can't land in a text column.
  lastError               String?       @db.VarChar(2000)
  consecutivePollFailures Int           @default(0)
  /// Set when the breaker trips (failures ≥ 5). Admin must flip
  /// `enabled` back on to clear. Distinct from `enabled=false` because
  /// we want to distinguish "admin turned it off" (DISABLED) from
  /// "system turned it off after errors" (FAILED).
  autoDisabledAt          DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt

  items                   NewsItem[]
  mediaItems              Media[]
  pollLogs                FeedPollLog[]
}

enum FeedKind {
  NEWS
  MEDIA
}

/// Editorial category for a Feed. Drives where the feed's items surface:
/// GENERAL → library /news (when that route ships), SPORTS → /sports
/// landing's HeadlinesRail. Sport-specific tagging on individual items
/// lives on NewsItem.sport, since one SPORTS feed can carry multiple
/// leagues (e.g., ESPN top stories).
enum FeedCategory {
  GENERAL
  SPORTS
}

/// Sport tag for SPORTS-category content. Used by NewsItem.sport (when
/// feed.category = SPORTS), SportsWag, SportsHighlight, SportsScheduleGame.
/// Add new leagues here as they're needed; downstream UIs filter by tag.
enum SportTag {
  NFL
  NBA
  MLB
  NHL
  MLS
  UFC
}

/// One RSS entry from a NEWS-kind feed. Dedupe key is `sourceUrl`
/// (normalized via src/lib/feed-types.ts: normalizeUrl). `guid` is the
/// RSS <guid> when present — used as a secondary dedup inside a feed
/// via the compound unique index.
///
/// NOT cascade-deleted on Media — these are a separate surface (/news),
/// not a library backing store. The `promote-to-library` admin action
/// creates a new Media row (via ingestUrl + persistIngest) and leaves
/// the NewsItem intact; later re-promotes are blocked by the unique
/// `sourceUrl` on Media.
model NewsItem {
  id          String    @id @default(uuid())
  feedId      String
  feed        Feed      @relation(fields: [feedId], references: [id], onDelete: Cascade)
  /// Normalized canonical URL. Unique across all feeds — two feeds
  /// publishing the same article collapse to one row, owned by
  /// whichever feed polled first.
  sourceUrl   String    @unique
  /// Raw URL from the feed, preserved so click-throughs go to the
  /// publisher's version (with their own tracking, their own path).
  originalUrl String
  guid        String?
  title       String
  excerpt     String?
  author      String?
  /// Nullable because feeds sometimes omit <pubDate> or lie (future
  /// dates, epoch 0). Query paths must COALESCE(publishedAt, ingestedAt).
  publishedAt DateTime?
  ingestedAt  DateTime  @default(now())
  ogImageUrl  String?
  /// Admin hide toggle. The /news grid filters hidden=false; the admin
  /// item browser shows everything.
  hidden      Boolean   @default(false)
  /// Sport tag, populated only when the parent Feed has category=SPORTS.
  /// Library (GENERAL) feeds leave this null. Drives per-sport filtering
  /// on the /sports HeadlinesRail.
  sport       SportTag?

  // Keyset pagination on /news: ORDER BY publishedAt DESC, id DESC.
  @@index([publishedAt(sort: Desc), id(sort: Desc)])
  // Per-feed item list on /admin/feeds/[id].
  @@index([feedId, publishedAt(sort: Desc)])
  // Sports HeadlinesRail query path (sport + recency).
  @@index([sport, publishedAt(sort: Desc)])
  // Secondary dedupe: same feed, same <guid> = same item even if URLs
  // differ by tracking params we didn't strip. Null guids allowed many
  // (Postgres null != null in compound unique).
  @@unique([feedId, guid], map: "NewsItem_feedId_guid_key")
}

/// Append-only log of every pollFeed invocation. One row per call.
/// Pruned daily by the prune cron to a 14-day retention (see PR B /
/// cron/prune-poll-logs.ts).
///
/// `outcome` is a text column (not enum) because the PollOutcome
/// discriminated union in src/lib/feed-types.ts can evolve without a
/// migration. Current values: "success" | "partial" | "failure" |
/// "skipped". The admin dashboards query by this column directly.
model FeedPollLog {
  id            String   @id @default(uuid())
  feedId        String
  feed          Feed     @relation(fields: [feedId], references: [id], onDelete: Cascade)
  startedAt     DateTime
  durationMs    Int
  outcome       String
  inserted      Int      @default(0)
  skipped       Int      @default(0)
  /// Serialized PollError[]. Null for success rows (Postgres doesn't
  /// love storing JSON defaults for null-meaning-absent semantics).
  errors        Json?

  // Per-feed sparkline + detail-page history.
  @@index([feedId, startedAt(sort: Desc)])
  // Cross-feed failure dashboard: "show me every feed that failed
  // overnight, newest first."
  @@index([outcome, startedAt(sort: Desc)])
}

// ---------------------------------------------------------------------------
// MLF Rookie Draft 2026 — foundation models.
//
// One DraftRoom per draft event (v1 = "mlf-2026"). DraftSlot maps each of
// the eight manager seats to a User. DraftPick carries the 24-pick snake
// grid with status transitions (pending → onClock → locked). DraftPoolPlayer
// tracks the per-draft rookie pool (seeded from SleeperPlayer + admin
// tweaks). RookieScoutingReport + DraftPickReaction cache the two AI
// pipelines (src/lib/sleeper-ai.ts). DraftAnnouncerImage is the Goodell-box
// image pool (random rotation per Q12; no per-pick-slot mapping).
// DraftSponsor is the per-draft sponsor rotation widget (Q15).
//
// All Draft* models cascade on DraftRoom delete so commissioner-initiated
// resets clear the full tree. User FKs use RESTRICT to force an explicit
// reassign before a manager deletion can land, except DraftPick.lockedById
// which SETs NULL (audit-only field, losing it is acceptable).
// ---------------------------------------------------------------------------

model DraftRoom {
  id             String    @id @default(uuid())
  /// Stable slug for URL + cross-reference. v1 = "mlf-2026".
  slug           String    @unique
  /// Human name, e.g., "MLF Rookie Draft 2026".
  name           String
  /// Season string matching PlayerSeasonStats.season semantics — "2026".
  season         String
  totalRounds    Int       @default(3)
  totalSlots     Int       @default(8)
  snake          Boolean   @default(true)
  /// One of: "setup" | "live" | "paused" | "complete". Text not enum so
  /// we can add transitional states without a migration. Validated by
  /// CHECK constraint in the migration.
  status         String    @default("setup")
  /// Soft-clock duration per pick in seconds. Default 24h (86400).
  /// "Soft" = UI turns red at zero, no auto-pick. Commissioner nudges.
  pickClockSec   Int       @default(86400)
  openedAt       DateTime?
  closedAt       DateTime?
  /// User ID snapshot of whoever created this draft. Plain string (not
  /// FK) so deleting the creator user doesn't orphan the draft — audit
  /// only, the admin UI resolves it to a display name at read time.
  createdBy      String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  slots          DraftSlot[]
  picks          DraftPick[]
  pool           DraftPoolPlayer[]
  announcerImgs  DraftAnnouncerImage[]
  sponsors       DraftSponsor[]
  shadowPicks    DraftShadowPick[]

  @@index([status])
}

/// One row per manager seat. Maps slotOrder (1..totalSlots) to a User.
/// teamName caches the Sleeper roster's team nickname at draft-setup
/// time so the Goodell caption reads from a stable source even if
/// Sleeper mutates. Admin can override teamName in setup.
model DraftSlot {
  id         String    @id @default(uuid())
  draftId    String
  slotOrder  Int
  userId     String
  teamName   String?
  /// True when this seat is shadow-managed by the commissioner (Joey /
  /// OORFV case). Shadow slots are held by a User with passwordHash=null;
  /// their picks are pre-seeded via DraftShadowPick and lock at openDraft
  /// time. The flag is here (not inferred from user.passwordHash) so
  /// behavior stays explicit — one can imagine real managers with OAuth-
  /// only accounts in the future, and the semantic "this slot is not
  /// staffed by a real participant" shouldn't collide with that.
  isShadow   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  draft       DraftRoom         @relation(fields: [draftId], references: [id], onDelete: Cascade)
  user        User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  picks       DraftPick[]
  shadowPicks DraftShadowPick[]

  @@unique([draftId, slotOrder])
  @@unique([draftId, userId])
}

/// The 24-cell snake grid. `overallPick` is 1..24, computed server-side
/// via computeSnakeOrder (src/lib/draft.ts) so the UI never has to infer
/// snake math. Status transitions: pending → onClock (when prior pick
/// locks) → locked (when user commits). `undoneAt` is non-null for picks
/// that were rolled back; the row stays for audit.
model DraftPick {
  id            String    @id @default(uuid())
  draftId       String
  round         Int
  pickInRound   Int
  overallPick   Int
  slotId        String
  /// User who owns this slot (denormalized from DraftSlot.userId).
  userId        String
  playerId      String?
  /// One of: "pending" | "onClock" | "locked". CHECK-constrained in SQL.
  status        String    @default("pending")
  onClockAt     DateTime?
  lockedAt      DateTime?
  /// User who actually clicked Lock. Usually equals userId. Different
  /// when admin picks on behalf of an AFK manager.
  lockedById    String?
  undoneAt      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  draft         DraftRoom            @relation(fields: [draftId], references: [id], onDelete: Cascade)
  slot          DraftSlot            @relation(fields: [slotId], references: [id], onDelete: Cascade)
  user          User                 @relation("DraftPickMaker", fields: [userId], references: [id], onDelete: Restrict)
  lockedBy      User?                @relation("DraftPickLocker", fields: [lockedById], references: [id], onDelete: SetNull)
  player        SleeperPlayer?       @relation(fields: [playerId], references: [playerId], onDelete: SetNull)
  reaction      DraftPickReaction?
  announcerImg  DraftAnnouncerImage?

  @@unique([draftId, overallPick])
  @@index([draftId, status])
  @@index([draftId, round, pickInRound])
}

/// The draftable rookie pool for a given draft. Auto-seeded from
/// SleeperPlayer (yearsExp=0, position in QB/RB/WR/TE, team IS NOT NULL).
/// Admin can add UDFA surprises manually and soft-remove with a note.
/// `removed=true` rows stay for audit (who removed, when, why).
model DraftPoolPlayer {
  id         String    @id @default(uuid())
  draftId    String
  playerId   String
  /// User ID snapshot (plain string, not FK) — audit only.
  addedBy    String
  removed    Boolean   @default(false)
  note       String?   @db.Text
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  draft      DraftRoom     @relation(fields: [draftId], references: [id], onDelete: Cascade)
  player     SleeperPlayer @relation(fields: [playerId], references: [playerId], onDelete: Cascade)

  @@unique([draftId, playerId])
  @@index([draftId, removed])
}

/// Per-rookie scouting report cached from Claude Sonnet 4.6. One row per
/// SleeperPlayer — the report is player-scoped, not draft-scoped, so the
/// same rookie's dossier can be shared across future drafts. Admin re-rolls
/// by deleting the row (generateRookieScoutingReport re-populates on next
/// view via single-flight in src/lib/sleeper-ai.ts).
model RookieScoutingReport {
  id         String   @id @default(uuid())
  playerId   String   @unique
  body       String   @db.Text
  /// One of: "analyst" | "scout" | "goodell". Admin-chosen default in
  /// DraftRoom settings; per-player override later if useful.
  voice      String   @default("analyst")
  /// Full model id the report was generated with (e.g., "claude-sonnet-4-6").
  /// Lets us audit generations after a model bump and re-roll if needed.
  model      String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  player     SleeperPlayer @relation(fields: [playerId], references: [playerId], onDelete: Cascade)
}

/// Per-pick AI reaction cached from Claude Sonnet 4.6. Fires fire-and-forget
/// from the lockPick server action; clients poll for presence. One row per
/// DraftPick (unique). Admin can regenerate by deleting the row (Q17 —
/// AI-only, no manual authoring). `characterId` null in v1 (neutral "MLF
/// draft announcer" voice); reserved for v1.1 character personas.
model DraftPickReaction {
  id           String    @id @default(uuid())
  draftPickId  String    @unique
  body         String    @db.Text
  characterId  String?
  model        String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  pick         DraftPick  @relation(fields: [draftPickId], references: [id], onDelete: Cascade)
  character    Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
}

/// Goodell-box image pool. Commissioner uploads ~30+ images pre-draft;
/// server picks one at random per pick-lock (without replacement until
/// pool exhausts, then resets). `consumedPickId` is SET when an image
/// fires for a pick; the unique constraint on it (nullable) means the
/// same image can't be reused within a single cycle. Clearing via admin
/// reset nulls consumedPickId back out for reuse. See Q12 (revised).
model DraftAnnouncerImage {
  id               String     @id @default(uuid())
  draftId          String
  r2Key            String
  /// Optional short label, e.g., "Joyce in a Bears jersey". Admin-only,
  /// shown in the image-pool management UI; not rendered publicly.
  label            String?
  /// User ID snapshot — plain string, audit only.
  uploadedBy       String
  /// FK to the DraftPick this image fired for. Null when unused.
  /// Setting this to non-null burns the image for the remainder of the
  /// rotation cycle. Admin "reset rotation" clears these back to null.
  consumedPickId   String?    @unique
  createdAt        DateTime   @default(now())

  draft            DraftRoom  @relation(fields: [draftId], references: [id], onDelete: Cascade)
  consumedPick     DraftPick? @relation(fields: [consumedPickId], references: [id], onDelete: SetNull)

  // "Pick a random unused image for this draft" — the pool-rotation query.
  @@index([draftId, consumedPickId])
}

/// Sponsor rotation widget (Q15). Per-draft only; doesn't persist across
/// drafts. Managed inline in /admin/draft/[id]/setup alongside slot order.
/// `active=false` hides the entry without deletion (useful for mid-draft
/// swaps). `displayOrder` drives the rotation sequence; admin can reorder.
/// `imageR2Key` + `linkUrl` reserved for v2; v1 renders text-only.
model DraftSponsor {
  id            String   @id @default(uuid())
  draftId       String
  name          String
  tagline       String?
  imageR2Key    String?
  linkUrl       String?
  displayOrder  Int      @default(0)
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  draft         DraftRoom @relation(fields: [draftId], references: [id], onDelete: Cascade)

  @@index([draftId, active, displayOrder])
}

/// Pre-seeded picks for shadow-managed slots. Written during setup (one
/// row per round per shadow slot), read by openDraft when materializing
/// the DraftPick grid — matching picks start as status=locked with this
/// playerId instead of status=pending. Shadow picks flow through the
/// rest of the system identically to real picks (announcer-image
/// rotation, reaction generation, Goodell caption).
///
/// `addedBy` is a plain User ID snapshot (not FK) — matches the audit-
/// field convention used on DraftRoom.createdBy and
/// DraftAnnouncerImage.uploadedBy.
model DraftShadowPick {
  id         String   @id @default(uuid())
  draftId    String
  slotId     String
  round      Int
  playerId   String
  addedBy    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  draft      DraftRoom     @relation(fields: [draftId], references: [id], onDelete: Cascade)
  slot       DraftSlot     @relation(fields: [slotId], references: [id], onDelete: Cascade)
  player     SleeperPlayer @relation(fields: [playerId], references: [playerId], onDelete: Cascade)

  @@unique([draftId, slotId, round])
  @@index([draftId, slotId])
}

// ---------------------------------------------------------------------------
// /sports landing redesign — see docs/sports-landing-redesign.md.
//
// Five surface modules: Headlines (NewsItem WHERE feed.category=SPORTS),
// WAG of the Day (SportsWag + SportsWagFeature), MLF Top 3 (Sleeper),
// TONIGHT (SportsScheduleGame), Highlights (SportsHighlight). Plus
// rotating sponsor (SportsSponsor) shown in two surfaces — hero presenter
// line + mid-page broadcast-break rail.
//
// Headlines and MLF reuse shipped infrastructure. The four models below
// are everything net-new for the landing.

/// Curated cross-sport WAG roster. Population path: admin form at
/// /admin/sports/wags with a "Find partner" button that calls the
/// generatePartnerByName helper extracted from src/lib/player-partner.ts.
/// Human-in-the-loop — the Gemini result auto-fills the form, KB confirms
/// or edits before save.
model SportsWag {
  id           String             @id @default(uuid())
  /// Partner's full name as displayed.
  name         String
  /// Athlete the partner is associated with — display field, not a FK.
  /// Free-form so non-Sleeper athletes (NBA/MLB/NHL/MMA) work too.
  athleteName  String
  sport        SportTag
  team         String?
  /// External image URL. Until the image proxy's host allow-list is
  /// extended (verified at PR 1 implementation), favor R2-uploaded URLs
  /// to keep next/image happy.
  imageUrl     String
  /// Instagram handle without the @. Matches the existing
  /// PlayerPartnerInfo convention.
  instagramUrl String?
  /// Editorial 1-liner shown beneath the name lockup.
  caption      String?            @db.VarChar(280)
  /// Soft delete. Hidden WAGs don't render even if scheduled.
  hidden       Boolean            @default(false)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  features     SportsWagFeature[]

  @@index([hidden])
}

/// Editorial schedule pinning a SportsWag to a calendar date. One WAG per
/// day, enforced by the unique constraint on featureDate. No fallback
/// hash-pick — when no row exists for today, the page shows "On break
/// today" rather than rolling a random pick.
model SportsWagFeature {
  id          String    @id @default(uuid())
  wagId       String
  wag         SportsWag @relation(fields: [wagId], references: [id], onDelete: Cascade)
  /// UTC date. The /sports landing reads `where: { featureDate: today }`.
  featureDate DateTime  @db.Date
  /// Optional override of SportsWag.caption for this feature. Lets the
  /// same WAG be scheduled multiple times with different editorial copy.
  caption     String?   @db.VarChar(280)

  @@unique([featureDate])
  @@index([featureDate])
}

/// YouTube highlight clip. Populated by /admin/sports/highlights (paste a
/// YouTube URL, oEmbed populates title/channel/thumb). PR 3 adds an
/// automated polling cron that watches a configured set of channels.
model SportsHighlight {
  id             String   @id @default(uuid())
  youtubeVideoId String   @unique
  title          String
  channel        String
  /// YouTube thumbnail URL (i.ytimg.com/…/hqdefault.jpg). Allow-list this
  /// host in next.config.mjs at PR 1 implementation.
  thumbUrl       String
  durationSec    Int?
  publishedAt    DateTime
  sport          SportTag
  hidden         Boolean  @default(false)
  /// Editorial pin — higher sortOrder wins. Ties broken by publishedAt.
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())

  @@index([hidden, publishedAt(sort: Desc)])
}

/// Scheduled game with where-to-watch info. Populated manually in PR 1
/// via /admin/sports/schedule. PR 4 adds a TheSportsDB / ESPN cron that
/// upserts via heuristic match on (sport, teams, gameTime ±6h).
model SportsScheduleGame {
  id          String         @id @default(uuid())
  sport       SportTag
  awayTeam    String
  homeTeam    String
  awayLogoUrl String?
  homeLogoUrl String?
  gameTime    DateTime
  network     String?
  watchUrl    String?
  status      ScheduleStatus @default(SCHEDULED)
  /// External provider ID (TheSportsDB or ESPN), populated by PR 4 sync.
  /// Admin-entered rows leave this null; PR 4's heuristic merge fills it
  /// when the synced row matches an existing manual entry.
  externalId  String?
  hidden      Boolean        @default(false)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  /// NULLs distinct in Postgres → admin (null externalId) and synced rows
  /// for the same game can coexist briefly until PR 4's merge runs.
  @@unique([sport, externalId])
  @@index([hidden, gameTime])
  @@index([sport, gameTime])
  /// Helper for PR 4's heuristic merge: find a manual row matching teams +
  /// game window before inserting a synced duplicate.
  @@index([sport, awayTeam, homeTeam, gameTime])
}

/// Rotating fake sponsor for the /sports landing. Mirrors DraftSponsor
/// (line 1325) but scoped to the landing rather than a draft event.
/// Active sponsors rotate by date hash — the same brand shows all day,
/// then advances at UTC midnight.
model SportsSponsor {
  id           String   @id @default(uuid())
  name         String
  /// Italic 1-liner displayed in quotes beneath the brand name.
  tagline      String?  @db.VarChar(140)
  /// Optional click-through URL. Mockups use # for fake-ad mode.
  href         String?
  active       Boolean  @default(true)
  /// Sort order within active set. Drives stable rotation across days.
  displayOrder Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([active, displayOrder])
}

/// Game status for SportsScheduleGame. SCHEDULED → LIVE → FINAL is the
/// happy path. POSTPONED is the rare exception. PR 4's live updater
/// flips status during game windows.
enum ScheduleStatus {
  SCHEDULED
  LIVE
  FINAL
  POSTPONED
}
