DATABASE_URL=
ANTHROPIC_API_KEY=
# Gemini — vision pipeline for library auto-tagging (P3).
# Paid tier strongly recommended — free tier trains on your inputs.
# Generate at https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=
SESSION_SECRET=

# SEED_CREDENTIALS is read by prisma/seed.ts when `npm run db:seed:reset` runs.
# Format: JSON array of { name, password } matching the 7 seeded User.name values.
# If a password contains a single quote, use double-quotes on the outer delimiter.
# Example:
# SEED_CREDENTIALS='[{"name":"KB","password":"changeme"},{"name":"Joey Fan 1","password":"changeme"}]'
SEED_CREDENTIALS=

# Sleeper — read-only fantasy football data (standings, rosters, transactions).
# Powers /sports/mlf + the lookup_sleeper agent tool. Public API, no key needed.
# Get your league id from https://sleeper.com/ → your league → URL tail.
SLEEPER_ENABLED=
SLEEPER_LEAGUE_ID=
# Optional overrides (ms). Defaults: 120_000 (2 min) and 86_400_000 (24h).
# SLEEPER_CACHE_TTL_MS=
# SLEEPER_PLAYERS_TTL_MS=

# Player profile partner lookup ("Off the field" card). Off by default.
# When flipped on: first view of a player profile fires a Claude call
# with Anthropic's web_search tool to populate PlayerPartnerInfo. Rows
# are cached indefinitely (delete to re-roll). Hotlinked images may
# break across CDNs; the UI falls back to initials on load error.
# Flip off if anything reads wrong for a given demo.
SLEEPER_PARTNERS_ENABLED=

# CRON_SECRET — shared header for the manual /api/cron/poll-feeds
# fallback. Header name `x-cron-secret`. The Trigger.dev scheduled
# task is the primary poll path now; this stays for incident-response
# manual triggers.
CRON_SECRET=

# Trigger.dev — durable background jobs (RSS feed polling, future
# sports score sync). Free tier covers projected load with ~78%
# headroom (verified 2026-04-29: ~14.5k runs/mo against $5/mo credit).
# Setup: see docs/trigger-dev-setup.md
#   1. Sign up at trigger.dev, create the lazyriverco project.
#   2. Replace the placeholder in trigger.config.ts with the real
#      project ref (looks like proj_<random>).
#   3. Set TRIGGER_SECRET_KEY below from project dashboard → API Keys.
#   4. Run `pnpm dlx trigger.dev@latest deploy` to push tasks.
TRIGGER_SECRET_KEY=

# Master kill switch for the Trigger.dev RSS feed poller. When unset
# or anything other than "true", the scheduled task is a no-op. Lets
# us pause polling without redeploying. Default OFF — flip to "true"
# in Railway env vars only after the Trigger.dev task has run cleanly
# from the dashboard at least once.
FEEDS_SYNC_ENABLED=

# Sports score sync — Trigger.dev tasks in src/trigger/sports.ts.
# Three schedules write to SportsScheduleGame:
#   sync-live-games   */5 * * * *    in-progress games (NFL/NBA/MLB/NHL)
#   sync-today-games  */15 * * * *   today's slate
#   sync-week-games   0 */6 * * *    next 7 days
#
# Two-level kill switch (architect-strategist 2026-04-29 review):
#   1. SPORTS_SYNC_ENABLED — master, short-circuits all sports
#      domains. One env-var flip pauses everything in an incident.
#   2. SPORTS_GAMES_SYNC_ENABLED — per-domain, lets future domains
#      (standings, players) be enabled independently.
#
# Both must be "true" for syncs to run. Default OFF until the tasks
# have run cleanly from the dashboard at least once.
SPORTS_SYNC_ENABLED=
SPORTS_GAMES_SYNC_ENABLED=
