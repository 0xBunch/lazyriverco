DATABASE_URL=
ANTHROPIC_API_KEY=
SESSION_SECRET=

# SEED_CREDENTIALS is read by prisma/seed.ts when `npm run db:seed:reset` runs.
# Format: JSON array of { name, password } matching the 7 seeded User.name values.
# If a password contains a single quote, use double-quotes on the outer delimiter.
# Example:
# SEED_CREDENTIALS='[{"name":"KB","password":"changeme"},{"name":"Joey Fan 1","password":"changeme"}]'
SEED_CREDENTIALS=
