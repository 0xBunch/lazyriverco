DATABASE_URL=
ANTHROPIC_API_KEY=
# Gemini — vision pipeline for library auto-tagging (P3).
# Paid tier strongly recommended — free tier trains on your inputs.
# Generate at https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=
SESSION_SECRET=

# SEED_CREDENTIALS is read by prisma/seed.ts when `npm run db:seed:reset` runs.
# Format: JSON array of { name, password } matching the 7 seeded User.name values.
# If a password contains a single quote, use double-quotes on the outer delimiter.
# Example:
# SEED_CREDENTIALS='[{"name":"KB","password":"changeme"},{"name":"Joey Fan 1","password":"changeme"}]'
SEED_CREDENTIALS=

# Sleeper — read-only fantasy football data (standings, rosters, transactions).
# Powers /fantasy + the lookup_sleeper agent tool. Public API, no key needed.
# Get your league id from https://sleeper.com/ → your league → URL tail.
SLEEPER_ENABLED=
SLEEPER_LEAGUE_ID=
# Optional overrides (ms). Defaults: 120_000 (2 min) and 86_400_000 (24h).
# SLEEPER_CACHE_TTL_MS=
# SLEEPER_PLAYERS_TTL_MS=
